generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  photo        String        @default("")
  motherId     String?
  mother       Contact?      @relation("UserMother", fields: [motherId], references: [id], onDelete: SetNull)
  fatherId     String?
  father       Contact?      @relation("UserFather", fields: [fatherId], references: [id], onDelete: SetNull)
  spouseId     String?
  spouse       Contact?      @relation("UserSpouse", fields: [spouseId], references: [id], onDelete: SetNull)
  passwordHash String
  sessions     Session[]
  contacts     Contact[]     @relation("OwnedContacts")
  circles      Circle[]
  debts        Debt[]
  pets         Pet[]
  createdAt    DateTime      @default(now())
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Contact {
  id               String          @id @default(cuid())
  userId           String
  user             User            @relation("OwnedContacts", fields: [userId], references: [id], onDelete: Cascade)
  firstName        String
  lastName         String          @default("")
  email            String          @default("")
  phone            String          @default("")
  company          String          @default("")
  photo            String          @default("")
  relationType     String          @default("")
  relationTags     ContactRelationTag[]
  birthday         DateTime?
  nameDayReference String          @default("")
  notes            String          @default("")
  desiredFrequency Int             @default(30)
  followUpStatus   String          @default("active")
  statusNote       String          @default("")
  deceasedAt       DateTime?
  source           String          @default("manual")
  sourceId         String          @default("")
  gender           String          @default("")
  motherId         String?
  mother           Contact?        @relation("Mother", fields: [motherId], references: [id], onDelete: SetNull)
  fatherId         String?
  father           Contact?        @relation("Father", fields: [fatherId], references: [id], onDelete: SetNull)
  spouseId         String?
  spouse           Contact?        @relation("Spouse", fields: [spouseId], references: [id], onDelete: SetNull)
  childrenAsMother Contact[]       @relation("Mother")
  childrenAsFather Contact[]       @relation("Father")
  spouses          Contact[]       @relation("Spouse")
  usersAsMother    User[]          @relation("UserMother")
  usersAsFather    User[]          @relation("UserFather")
  usersAsSpouse    User[]          @relation("UserSpouse")
  circles          CircleMember[]
  interactions     Interaction[]
  reminders        Reminder[]
  giftIdeas        GiftIdea[]
  journalEntries   JournalEntry[]
  importantDates   ImportantDate[]
  conversationItems ConversationItem[]
  customFields     CustomField[]
  linksFrom        ContactLink[]   @relation("LinkFrom")
  linksTo          ContactLink[]   @relation("LinkTo")
  debts            Debt[]
  pets             PetOwner[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model ContactRelationTag {
  contactId String
  tag       String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([contactId, tag])
}

model Circle {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  color        String         @default("#6d5dfc")
  frequency    Int            @default(30)
  weeklyTarget Int            @default(1)
  members      CircleMember[]
  createdAt    DateTime       @default(now())
}

model CircleMember {
  contactId String
  circleId  String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  circle    Circle  @relation(fields: [circleId], references: [id], onDelete: Cascade)

  @@id([contactId, circleId])
}

model Interaction {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  type      String   @default("message")
  note      String   @default("")
  happenedAt DateTime @default(now())
  createdAt DateTime @default(now())
}

model Reminder {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  kind      String   @default("contact")
  title     String
  dueAt     DateTime
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model GiftIdea {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  title     String
  url       String   @default("")
  price     Float?
  note      String   @default("")
  purchased Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ContactLink {
  id            String   @id @default(cuid())
  fromContactId String
  toContactId   String
  fromContact   Contact  @relation("LinkFrom", fields: [fromContactId], references: [id], onDelete: Cascade)
  toContact     Contact  @relation("LinkTo", fields: [toContactId], references: [id], onDelete: Cascade)
  source        String   @default("mention")
  label         String   @default("")
  note          String   @default("")
  relationType  String   @default("") // Conservé pour compatibilité, non utilisé par l'arbre
  createdAt     DateTime @default(now())

  @@unique([fromContactId, toContactId])
}

model JournalEntry {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  type      String   @default("note")
  title     String
  content   String   @default("")
  happenedAt DateTime @default(now())
  private   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ImportantDate {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  title     String
  date      DateTime
  recurring Boolean @default(true)
  remindDays Int    @default(7)
  source    String   @default("manual")
  sourceKey String?
  createdAt DateTime @default(now())

  @@unique([contactId, sourceKey])
}

model ConversationItem {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  kind      String   @default("topic")
  title     String
  detail    String   @default("")
  done      Boolean  @default(false)
  private   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model CustomField {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  label     String
  value     String
  private   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Debt {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  direction String
  amount    Float
  currency  String   @default("EUR")
  title     String
  note      String   @default("")
  dueAt     DateTime?
  settled   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Pet {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  species   String
  breed     String     @default("")
  photo     String     @default("")
  birthday  DateTime?
  notes     String     @default("")
  owners    PetOwner[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model PetOwner {
  petId     String
  contactId String
  pet       Pet     @relation(fields: [petId], references: [id], onDelete: Cascade)
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([petId, contactId])
}
